.pdf-fallback-container {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rem;
  min-height: 80vh;
}

.fallback-card {
  padding: 4rem;
  text-align: center;
  max-width: 500px;
  display: flex;
  flex-direction: column;
  items-center: center;
  gap: 1.5rem;
}

.fallback-card h2 {
  font-size: 2rem;
  color: var(--color-accent-gold);
}

.fallback-card p {
  opacity: 0.7;
}

.fallback-card .btn-premium {
  margin-top: 1rem;
}
